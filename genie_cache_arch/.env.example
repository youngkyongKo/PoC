# Databricks Configuration
DATABRICKS_HOST=e2-demo-field-eng.cloud.databricks.com
DATABRICKS_TOKEN=your_token_here

# Genie Configuration
GENIE_SPACE_ID=01f1115dc00f1fd7809cb280333f7fb2

# Vector Search Configuration
VECTOR_SEARCH_ENDPOINT=one-env-shared-endpoint-11
VECTOR_SEARCH_INDEX=demo_ykko.genie_cache.semantic_cache_index

# Lakebase Configuration (Autoscale)
LAKEBASE_PROJECT_NAME=ykko-genie-cache-db
LAKEBASE_BRANCH=production
LAKEBASE_ENDPOINT=primary
LAKEBASE_SCHEMA=geniecache
LAKEBASE_HOST=your_lakebase_host_from_endpoint
LAKEBASE_PORT=5432

# Cache Configuration
STATIC_CACHE_TTL_SECONDS=86400
SEMANTIC_SIMILARITY_THRESHOLD=0.85
SEMANTIC_SIMILARITY_SECONDARY_THRESHOLD=0.75

# Retry Configuration
GENIE_MAX_RETRIES=5
GENIE_INITIAL_DELAY=1.0
GENIE_MAX_DELAY=32.0
GENIE_BACKOFF_MULTIPLIER=2.0

# Unity Catalog
UC_CATALOG=demo_ykko
UC_SCHEMA=genie_cache

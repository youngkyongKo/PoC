{
  "name": "demo_job_main",
  "tasks": [
    {
      "task_key": "task1_run_job_sub1",
      "run_job_task": {
        "job_id": "{{JOB_SUB1_ID}}"
      },
      "timeout_seconds": 1200
    },
    {
      "task_key": "task2_sql_query",
      "depends_on": [
        {
          "task_key": "task1_run_job_sub1"
        }
      ],
      "sql_task": {
        "warehouse_id": "{{WAREHOUSE_ID}}",
        "query": {
          "query": "SELECT 'SQL Task Demo' as message, current_timestamp() as execution_time, '✅ Task completed' as status"
        }
      },
      "timeout_seconds": 600
    },
    {
      "task_key": "task3_run_job_sub2",
      "depends_on": [
        {
          "task_key": "task2_sql_query"
        }
      ],
      "run_job_task": {
        "job_id": "{{JOB_SUB2_ID}}"
      },
      "timeout_seconds": 1200
    }
  ],
  "format": "MULTI_TASK"
}

# Databricks Configuration
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-personal-access-token

# Unity Catalog Configuration
UC_CATALOG=your_catalog
UC_SCHEMA=your_schema
UC_VOLUME=your_volume

# Vector Search Configuration
VECTOR_SEARCH_ENDPOINT=your_vector_search_endpoint
VECTOR_INDEX_NAME=your_catalog.your_schema.pdf_embeddings_index

# Genie Space Configuration
GENIE_SPACE_ID=your_genie_space_id
SQL_WAREHOUSE_ID=your_warehouse_id

# Model Configuration
EMBEDDING_MODEL=databricks-bge-large-en
LLM_MODEL=databricks-dbrx-instruct
SERVING_ENDPOINT=databricks-dbrx-instruct

# Voice Configuration
SPEECH_LANGUAGE=ko-KR
TTS_LANGUAGE=ko
AUDIO_SAMPLE_RATE=16000

# Application Settings
DEBUG=True
LOG_LEVEL=INFO
